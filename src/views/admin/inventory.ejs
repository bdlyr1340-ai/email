<%- include('../partials/admin-header', { title: 'المخزون' }) %>
<div class="page-title"><div><h1>مخزون: <%= variant.product_name %></h1><p><%= variant.name_ar %> — <%= variant.stock_mode %></p></div></div>
<% if (message) { %><div class="notice success"><%= message %></div><% } %>
<section class="card"><h2>إضافة حسابات / عناصر</h2><p>كل سطر يمثل حساباً أو عنصراً. الصيغ المدعومة: <code>email|password|2FA</code> أو <code>email|password</code> أو <code>email</code> أو JSON.</p><form method="post" enctype="multipart/form-data" class="form-grid"><label class="full"><span>لصق الحسابات</span><textarea name="inventory_text" rows="8" placeholder="mail@example.com|password|2FA secret"></textarea></label><label><span>أو ارفع ملف TXT</span><input type="file" name="inventory_file" accept=".txt,.csv"></label><label><span>عدد الاستخدامات لكل حساب مشترك</span><input type="number" name="capacity" value="<%= variant.metadata?.shared_capacity || 5 %>" min="1" max="100"></label><label><span>انتهاء الحساب الرئيسي (اختياري)</span><input type="datetime-local" name="expires_at"></label><button class="primary full">إضافة للمخزون</button></form></section>
<% if (variant.stock_mode === 'SHARED_SLOT') { %><section class="card"><h2>الحسابات المشتركة</h2><div class="table-wrap"><table><thead><tr><th>الحساب</th><th>الخانات</th><th>مباع</th><th>متوفر</th><th>الحالة</th></tr></thead><tbody><% inventory.groups.forEach(g => { %><tr><td><%= g.label %></td><td><%= g.slots_total %></td><td><%= g.slots_sold %></td><td><%= g.slots_available %></td><td><%= g.active ? 'يُباع حالياً' : 'ممتلئ/متوقف' %></td></tr><% }) %></tbody></table></div></section><% } else { %><section class="card"><h2>العناصر الفردية</h2><div class="table-wrap"><table><thead><tr><th>العنصر</th><th>الحالة</th><th>تاريخ الإضافة</th></tr></thead><tbody><% inventory.items.forEach(i => { %><tr><td><%= i.label %></td><td><%= i.status %></td><td><%= new Date(i.created_at).toLocaleString('ar-IQ') %></td></tr><% }) %></tbody></table></div></section><% } %>
<%- include('../partials/admin-footer') %>
