<%- include('../partials/admin-header', { title: `طلب #${order.order_number}` }) %>
<div class="page-title"><div><h1>طلب #<%= order.order_number %></h1><p><%= order.customer_name %> — <%= order.customer_contact %></p></div><span class="status status-<%= order.status.toLowerCase() %>"><%= order.status %></span></div>
<section class="card"><div class="order-meta"><div><span>الدفع</span><b><%= order.payment_provider %></b></div><div><span>المبلغ</span><b><%= money(order.total_amount,order.currency) %></b></div><div><span>أنشئ</span><b><%= new Date(order.created_at).toLocaleString('ar-IQ') %></b></div></div><% if (order.status === 'PENDING') { %><form method="post" action="/admin/orders/<%= order.id %>/mark-paid"><button class="primary">تأكيد الدفع يدوياً</button></form><% } %></section>
<% order.items.forEach(item => { %><section class="card"><h2><%= item.product_name_ar %> — <%= item.variant_name_ar %></h2><p>حالة التسليم: <b><%= item.fulfillment_status %></b></p><% if (item.delivery) { Object.entries(item.delivery).forEach(([k,v]) => { %><div class="credential"><span><%= k %></span><code><%= typeof v === 'object' ? JSON.stringify(v) : v %></code></div><% }) } %><% if (['WAIT_CODE','MANUAL'].includes(item.fulfillment_status)) { %><form method="post" action="/admin/orders/<%= order.id %>/deliver/<%= item.id %>"><label><span>الكود أو رسالة التسليم</span><textarea name="code" required rows="3"></textarea></label><button class="primary">إرسال وإكمال التسليم</button></form><% } %></section><% }) %>
<%- include('../partials/admin-footer') %>
